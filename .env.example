# ==================================================================
# Project Zenith — Environment Configuration
# ==================================================================
# Single source of truth for all environment variables.
# Both frontend and backend read from this file.
# See monorepo-governance.md §4 for details.
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==================================================================

# === Frontend Configuration ===
NEXT_PUBLIC_CES_DEPLOYMENT_NAME=projects/YOUR_PROJECT_NUMBER/locations/us/apps/YOUR_APP_ID/deployments/YOUR_DEPLOYMENT_ID
