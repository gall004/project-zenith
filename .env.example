# ==================================================================
# Project Zenith — Environment Configuration
# ==================================================================
# Single source of truth for all environment variables.
# Both frontend and backend read from this file.
# See monorepo-governance.md §4 for details.
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==================================================================

# === LiveKit ===
LIVEKIT_API_KEY=your_key_here
LIVEKIT_API_SECRET=your_secret_here
LIVEKIT_URL=wss://your-livekit-server.com

# === Gemini ===
GEMINI_API_KEY=mock-key-for-dev

# === Database ===
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/zenith
REDIS_URL=redis://localhost:6379/0

# === Frontend (NEXT_PUBLIC_ prefix required for client exposure) ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server.com
NEXT_PUBLIC_MAX_ATTACHMENT_SIZE_MB=5
NEXT_PUBLIC_ALLOWED_ATTACHMENT_TYPES=image/jpeg,image/png,image/webp,image/gif

# === GECX Agent (CX Agent Studio deployment) ===
# Authentication: Uses ADC (run 'gcloud auth application-default login')
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
CES_REGION=us
CES_APP_ID=your-ces-app-id
FASTAPI_BACKEND_URL=https://your-domain.ngrok-free.dev

# === Ngrok Dev Tunnel ===
# Static ngrok domain for CES webhook reachability in local dev.
# Get a free static domain at: https://dashboard.ngrok.com/domains
# Get your authtoken at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
NGROK_DOMAIN=your-domain.ngrok-free.dev
