# =========================
# Project Zenith .gitignore
# =========================

# --- Dependencies ---
node_modules/
.pnp/
.pnp.js

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
uv.lock

# --- Environment ---
# Root .env is the single source of truth (gitignored — contains secrets)
.env
# Per-stack env files are FORBIDDEN per monorepo-governance.md §4
# but gitignored as a safety net in case they are accidentally created
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env*
backend/.env*
# .env.example IS committed (contains no secrets)

# --- Next.js ---
.next/
out/

# --- Build ---
*.tsbuildinfo

# --- Testing ---
coverage/
.coverage
htmlcov/
.pytest_cache/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS ---
Thumbs.db

# --- Scratch ---
.scratch/
