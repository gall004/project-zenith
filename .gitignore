# =========================
# Project Zenith .gitignore
# =========================

# --- Dependencies ---
node_modules/
.pnp/
.pnp.js

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/

# --- Environment ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example files ARE committed (they contain no secrets)

# --- Next.js ---
.next/
out/

# --- Build ---
*.tsbuildinfo

# --- Testing ---
coverage/
.coverage
htmlcov/
.pytest_cache/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS ---
Thumbs.db
