# ==================================================================
# Project Zenith — Production Deployment Configuration
# ==================================================================
# Single source of truth for all deployment settings.
# Both deploy.sh and teardown.sh read from this file.
#
# Fill in your values once. The deploy script is idempotent —
# re-run it any time to push a new version.
# ==================================================================

# === GCP Project ===
PROJECT_ID="strategy-and-demonstration"
REGION="us-central1"

# === Custom Domain ===
# Leave empty to skip domain mapping.
FRONTEND_DOMAIN="project-zenith.tthcslabs.com"
BACKEND_DOMAIN="api.project-zenith.tthcslabs.com"

# === Cloud Run Service Names ===
BACKEND_SERVICE="zenith-backend"
FRONTEND_SERVICE="zenith-frontend"

# === Artifact Registry ===
AR_REPO="zenith"

# === Service Accounts ===
BACKEND_SA="zenith-backend-sa"

# === Memorystore (Redis) ===
REDIS_INSTANCE="zenith-redis"
REDIS_TIER="BASIC"
REDIS_SIZE_GB="1"

# === VPC Connector ===
VPC_CONNECTOR="agent-assist-connector"
VPC_NETWORK="agent-assist-vpc-network"
VPC_RANGE="10.8.0.0/28"

# === Secret Manager Secret Names ===
# These are the names of secrets in Secret Manager.
SECRET_LIVEKIT_API_KEY="zenith-livekit-api-key"
SECRET_LIVEKIT_API_SECRET="zenith-livekit-api-secret"
SECRET_GEMINI_API_KEY="zenith-gemini-api-key"

# === Secret Values ===
# If provided, deploy.sh will automatically inject these into Secret Manager.
LIVEKIT_API_KEY="APIx56KgnntAiFs"
LIVEKIT_API_SECRET="2a4XPF12C8W5tcfBLXf2x1pRx8tSwM2R19KRsat7FDu"
GEMINI_API_KEY="AIzaSyDxkNUBxfqy2k8OOiaNIuL5nZv-AyD142E"

# === App Configuration (non-secret) ===
LIVEKIT_URL="wss://project-zenith-n2nnxmod.livekit.cloud"
GCP_REGION="us-central1"
CES_APP_ID=38e00ae7-4e71-4978-b574-20c5b015c939
CES_REGION="us"
GECX_APP_NAME="zenith-gecx-orchestrator-prod"

# === Cloud Run Sizing ===
BACKEND_MEMORY="1Gi"
BACKEND_CPU="2"
BACKEND_MIN_INSTANCES="1"
BACKEND_MAX_INSTANCES="5"
BACKEND_TIMEOUT="3600"

FRONTEND_MEMORY="512Mi"
FRONTEND_CPU="1"
FRONTEND_MIN_INSTANCES="0"
FRONTEND_MAX_INSTANCES="3"
GECX_AGENT_ID=216c732d-49ab-4501-808a-accbdc1e9a5e
