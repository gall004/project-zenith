{
  "openapi": "3.1.0",
  "info": {
    "title": "Project Zenith Backend",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Health check",
        "description": "Standardized health probe for production readiness.\nVerifies connectivity to LiveKit and Redis.",
        "operationId": "health_check_api_v1_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse_dict_"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/rooms/tokens": {
      "post": {
        "tags": [
          "Rooms"
        ],
        "summary": "Generate LiveKit Token",
        "description": "Generate a secure AccessToken for the LiveKit server (US-01).",
        "operationId": "create_token_api_v1_rooms_tokens_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse_TokenResponseData_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "summary": "Create or resume a session",
        "description": "Create a new session or resume an existing one.\n\nIf the caller provides an ``identity`` that already has an active\nsession, the existing session is returned (idempotent resume).\nOtherwise a fresh session is created.",
        "operationId": "create_session_api_v1_sessions_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse_CreateSessionResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{room_name}": {
      "get": {
        "tags": [
          "Sessions"
        ],
        "summary": "Hydrate session state",
        "description": "Return the full session state from Redis for frontend hydration.\n\nThe frontend calls this on every mount (including after refresh)\nto restore identity, multimodal state, escalation data, and status.",
        "operationId": "get_session_api_v1_sessions__room_name__get",
        "parameters": [
          {
            "name": "room_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Room Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse_SessionState_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Sessions"
        ],
        "summary": "End an active session",
        "description": "Explicitly terminate a session: stop pipeline, purge Redis state.",
        "operationId": "end_session_api_v1_sessions__room_name__delete",
        "parameters": [
          {
            "name": "room_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Room Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse_dict_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{room_name}/transcript": {
      "get": {
        "tags": [
          "Sessions"
        ],
        "summary": "Retrieve chat transcript",
        "description": "Return the full ordered chat transcript for a session.\n\nThe frontend calls this on mount to hydrate the message list\nwithout relying on sessionStorage.",
        "operationId": "get_transcript_api_v1_sessions__room_name__transcript_get",
        "parameters": [
          {
            "name": "room_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Room Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse_list_TranscriptMessage__"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/agent/webhook": {
      "post": {
        "tags": [
          "Agent"
        ],
        "summary": "CES Tool Webhook",
        "description": "Handle the request_visual_context OpenAPI tool execution.\n\nThe GECX agent in CX Agent Studio triggers this endpoint when\nit decides to execute the request_visual_context OpenAPI tool.",
        "operationId": "request_visual_context_endpoint_api_v1_agent_webhook_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VisualContextRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VisualContextResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateSessionRequest": {
        "properties": {
          "identity": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Identity"
          }
        },
        "type": "object",
        "title": "CreateSessionRequest",
        "description": "POST /api/v1/sessions request body."
      },
      "CreateSessionResponse": {
        "properties": {
          "room_name": {
            "type": "string",
            "title": "Room Name"
          },
          "identity": {
            "type": "string",
            "title": "Identity"
          },
          "status": {
            "$ref": "#/components/schemas/SessionStatus"
          }
        },
        "type": "object",
        "required": [
          "room_name",
          "identity",
          "status"
        ],
        "title": "CreateSessionResponse",
        "description": "POST /api/v1/sessions response body."
      },
      "ErrorDetail": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "ErrorDetail"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ResponseMeta": {
        "properties": {
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          },
          "request_id": {
            "type": "string",
            "title": "Request Id"
          }
        },
        "type": "object",
        "title": "ResponseMeta"
      },
      "SessionState": {
        "properties": {
          "room_name": {
            "type": "string",
            "title": "Room Name"
          },
          "identity": {
            "type": "string",
            "title": "Identity"
          },
          "status": {
            "$ref": "#/components/schemas/SessionStatus",
            "default": "active"
          },
          "multimodal_event": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Multimodal Event"
          },
          "escalation_data": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Escalation Data"
          },
          "created_at": {
            "type": "string",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "room_name",
          "identity"
        ],
        "title": "SessionState",
        "description": "Canonical session state persisted in Redis.\n\nMirrors the fields previously scattered across frontend\n``sessionStorage`` keys (zenith_identity, zenith_room,\nzenith_multimodal, zenith_escalation)."
      },
      "SessionStatus": {
        "type": "string",
        "enum": [
          "active",
          "escalated",
          "ended"
        ],
        "title": "SessionStatus",
        "description": "Lifecycle status of a session."
      },
      "StandardResponse_CreateSessionResponse_": {
        "properties": {
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CreateSessionResponse"
              },
              {
                "type": "null"
              }
            ]
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ErrorDetail"
              },
              {
                "type": "null"
              }
            ]
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        },
        "type": "object",
        "title": "StandardResponse[CreateSessionResponse]"
      },
      "StandardResponse_SessionState_": {
        "properties": {
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SessionState"
              },
              {
                "type": "null"
              }
            ]
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ErrorDetail"
              },
              {
                "type": "null"
              }
            ]
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        },
        "type": "object",
        "title": "StandardResponse[SessionState]"
      },
      "StandardResponse_TokenResponseData_": {
        "properties": {
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TokenResponseData"
              },
              {
                "type": "null"
              }
            ]
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ErrorDetail"
              },
              {
                "type": "null"
              }
            ]
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        },
        "type": "object",
        "title": "StandardResponse[TokenResponseData]"
      },
      "StandardResponse_dict_": {
        "properties": {
          "data": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Data"
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ErrorDetail"
              },
              {
                "type": "null"
              }
            ]
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        },
        "type": "object",
        "title": "StandardResponse[dict]"
      },
      "StandardResponse_list_TranscriptMessage__": {
        "properties": {
          "data": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/TranscriptMessage"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Data"
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ErrorDetail"
              },
              {
                "type": "null"
              }
            ]
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        },
        "type": "object",
        "title": "StandardResponse[list[TranscriptMessage]]"
      },
      "TokenRequest": {
        "properties": {
          "room_name": {
            "type": "string",
            "title": "Room Name"
          },
          "participant_identity": {
            "type": "string",
            "title": "Participant Identity"
          },
          "participant_name": {
            "type": "string",
            "title": "Participant Name",
            "default": "Participant"
          }
        },
        "type": "object",
        "required": [
          "room_name",
          "participant_identity"
        ],
        "title": "TokenRequest"
      },
      "TokenResponseData": {
        "properties": {
          "token": {
            "type": "string",
            "title": "Token"
          }
        },
        "type": "object",
        "required": [
          "token"
        ],
        "title": "TokenResponseData"
      },
      "TranscriptMessage": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "text": {
            "type": "string",
            "title": "Text"
          },
          "sender": {
            "type": "string",
            "title": "Sender"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "id",
          "text",
          "sender",
          "timestamp"
        ],
        "title": "TranscriptMessage",
        "description": "A single chat message stored in the transcript list."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VisualContextRequest": {
        "properties": {
          "reason": {
            "type": "string",
            "title": "Reason",
            "description": "Reason the agent requested camera access"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id",
            "description": "Target room name"
          }
        },
        "type": "object",
        "required": [
          "reason"
        ],
        "title": "VisualContextRequest",
        "description": "Schema for incoming CES tool webhook payloads (request_visual_context)."
      },
      "VisualContextResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "camera_enabled": {
            "type": "boolean",
            "title": "Camera Enabled"
          }
        },
        "type": "object",
        "required": [
          "status",
          "message",
          "camera_enabled"
        ],
        "title": "VisualContextResponse"
      }
    }
  }
}